# Copy to .env for local dev. The dev/migrate/seed scripts load it via
# `tsx --env-file=.env`; shell env vars take precedence over these values.
#
# Native PostgreSQL + PostGIS on 5432 (compose maps to 5433 instead — use that
# port if running via docker compose).
DATABASE_URL=postgres://bioverse:bioverse@localhost:5432/bioverse
JWT_SECRET=dev-local-secret-change-me
REDIS_URL=redis://localhost:6379
PORT=3000
HOST=0.0.0.0
